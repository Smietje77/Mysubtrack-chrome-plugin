{
  "manifest_version": 3,
  "name": "MySubTrack - Subscription Detector",
  "version": "1.1.0",
  "description": "Detects subscription pages (known and generic) and lets users add them to MySubTrack.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "MySubTrack",
    "default_popup": "popup.html"
  }
}
